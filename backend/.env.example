# Database
DATABASE_URL=postgresql+psycopg://ahc:ahc_password@localhost:5432/ahc_db

# JWT
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# HR REST API integration.
# By default points to the built-in mock HR portal so the flow works end-to-end.
# Point this at a real HR portal endpoint in production.
HR_API_URL=http://localhost:8000/mock-hr/ahc-updates
HR_API_KEY=mock-hr-api-key

# Shared secret the hospital partner uses to authenticate completion webhooks.
HOSPITAL_WEBHOOK_SECRET=hospital-webhook-secret
